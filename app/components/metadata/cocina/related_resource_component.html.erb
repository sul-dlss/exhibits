<dd>
  <% if labeled_link %>
    <dl>
      <dt><%= labeled_link %></dt>
      <dd>
        <dl><%= render Metadata::Cocina::FieldComponent.with_collection(display_data) %></dl>
      </dd>
    </dl>
  <% elsif summary %>
    <details data-details-container-target="detailItem" data-action="details-container#toggleButtonText">
      <summary><%= summary %></summary>
      <dl><%= render Metadata::Cocina::FieldComponent.with_collection(display_data) %></dl>
    </details>
  <% else %>
    <dl><%= render Metadata::Cocina::FieldComponent.with_collection(display_data) %></dl>
  <% end %>
</dd>
